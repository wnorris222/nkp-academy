# Copy to .env for local runs. All keys are optional (sensible defaults apply).
# Every variable maps to a Settings field in backend/app/config.py.

# App
NKP_ENVIRONMENT=development
NKP_DEBUG=false
NKP_AUTO_SEED=true

# Data layer — SQLite by default; swap to PostgreSQL by uncommenting below.
NKP_DATABASE_URL=sqlite+aiosqlite:///./nkp_academy.db
# NKP_DATABASE_URL=postgresql+asyncpg://nkp:nkp@localhost:5432/nkp_academy

# Content location (YAML modules + badges)
NKP_CONTENT_DIR=./content

# Static SPA build (set in the container; leave empty for host dev with Vite)
# NKP_STATIC_DIR=./frontend/dist

# CORS origins for the Vite dev server
NKP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
